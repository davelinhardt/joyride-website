{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/index", "destination": "/index.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/drivers", "destination": "/drivers.html" },
    { "source": "/riders", "destination": "/riders.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/design-system", "destination": "/design-system.html" },
    { "source": "/driver", "destination": "/driver.html" },
    { "source": "/rides", "destination": "/rides.html" },
    { "source": "/receipt", "destination": "/receipt.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/subscription", "destination": "/subscription.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/community-guidelines", "destination": "/community-guidelines.html" },
    { "source": "/driver-addendum", "destination": "/driver-addendum.html" },
    { "source": "/anti-discrimination", "destination": "/anti-discrimination.html" },
    { "source": "/service-animal-policy", "destination": "/service-animal-policy.html" },
    { "source": "/accessibility", "destination": "/accessibility.html" },
    { "source": "/cancellation-policy", "destination": "/cancellation-policy.html" },
    { "source": "/harassment-policy", "destination": "/harassment-policy.html" },
    { "source": "/copyright", "destination": "/copyright.html" },
    { "source": "/cookies", "destination": "/cookies.html" },
    { "source": "/raise1", "destination": "/raise1.html" },
    { "source": "/raise1/uber_analysis", "destination": "/raise1-uber-analysis.html" },
    { "source": "/raise1/tam", "destination": "/raise1-tam.html" },
    { "source": "/raise1/invest", "destination": "/raise1-invest.html" },
    { "source": "/:slug", "destination": "/driver.html?u=:slug" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/assets/illo(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/assets/lockup(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/assets/mark(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/assets/wordmark(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/assets/favicon(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
