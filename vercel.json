{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/index",         "destination": "/index.html" },
    { "source": "/login",         "destination": "/login.html" },
    { "source": "/account",       "destination": "/account.html" },
    { "source": "/drivers",       "destination": "/drivers.html" },
    { "source": "/riders",        "destination": "/riders.html" },
    { "source": "/blog",          "destination": "/blog.html" },
    { "source": "/contact",       "destination": "/contact.html" },
    { "source": "/design-system", "destination": "/design-system.html" },
    { "source": "/driver",        "destination": "/driver.html" },
    {
      "source": "/:slug([A-Za-z0-9_-]+)",
      "destination": "/driver.html?u=:slug"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
